# .env – Umgebungsvariablen für das Vue-Frontend
# ══════════════════════════════════════════════════
#
# VITE_* Variablen werden vom Vite-Build-Tool geladen
# und sind im Frontend-Code über import.meta.env.VITE_* abrufbar.
#
# WICHTIG: Nie Secret Keys hier speichern!
# Diese Datei wird in das Git-Repo eingecheckt.
# Für Produktionsgeheimnisse → .env.production.local (gitignored)

# Basis-URL der Django REST API
# • Lokal (ohne Docker): http://localhost:8000
# • Mit Docker-Compose: http://localhost:8000 (Port wird gemappt)
# • Der Vite-Proxy leitet /api/* ohnehin weiter, daher oft leer lassen
VITE_API_BASE_URL=http://localhost:8000

# Interner Docker-Zielname für den Proxy
# (nur von vite.config.ts gelesen, nicht vom Frontend-Code)
VITE_API_TARGET=http://backend:8000
